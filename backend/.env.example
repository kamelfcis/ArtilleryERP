# PostgreSQL — Supabase URI works for dev; VPS URI for production
DATABASE_URL=postgresql://artillery_app:password@localhost:5432/artillery_erp

# JWT signing secret (generate: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=4000
NODE_ENV=development

# Comma-separated allowed browser origins
CORS_ORIGINS=http://localhost:3000,https://artilleryerp.vercel.app

# Cookie name for auth token
COOKIE_NAME=artillery_token

# Cloudflare R2 (presign / delete / health under /storage/*)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=artillery
# Public CDN base (no trailing slash); NEXT_PUBLIC_R2_CDN_URL also accepted
R2_CDN_URL=https://pub-xxxxxxxx.r2.dev
