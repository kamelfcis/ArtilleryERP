# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# backend
backend/node_modules/
backend/dist/
backend/.env

# migration backups (may contain production data)
scripts/migration/backups/
migration-dumps/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PM2 logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Large binary/archive files
*.rar
*.ldf
*.sql
!supabase/**/*.sql

# Non-essential docs
*.docx

# Supabase CLI temp
supabase/.temp/
